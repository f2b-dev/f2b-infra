# 灵境云本地/单机端口约定（专属，避免与常见 3000/8787 冲突）
# web 控制台 + BFF
F2B_WEB_PORT=13200
# sandbox 产品 API
F2B_SANDBOX_PORT=13287

# 单机并发硬顶（可选；写入 sandbox 服务环境）
# F2B_MAX_CONCURRENT_SANDBOXES=5
# sandbox 监听：测试机/生产建议 127.0.0.1，仅本机 BFF 访问
# F2B_SANDBOX_HOST=127.0.0.1
# F2B_AUTH_MODE=off
# F2B_ADMIN_TOKEN=
# F2B_SANDBOX_API_KEY=   # web BFF 上游产品密钥（auth=api_key 时）
# F2B_CUBE_API_URL=http://127.0.0.1:<cube-api-port>
# F2B_CUBE_API_TOKEN=
