# 宿主机端口映射（all-in-one 约定：3000=web，8787=sandbox）
F2B_WEB_PORT=3000
F2B_SANDBOX_PORT=8787

# fake = 无 KVM 开发；单机真数据面时改为非 fake 并配置 F2B_CUBE_*（仅 sandbox，勿提交真实密钥）
# 进程/目录约定见 docs/all-in-one.md
F2B_SANDBOX_BACKEND=fake
# 单机并发硬顶（可选；写入 sandbox 服务环境）
# F2B_MAX_CONCURRENT_SANDBOXES=5
# sandbox 监听：测试机/生产建议 127.0.0.1，仅本机 BFF 访问
# F2B_SANDBOX_HOST=127.0.0.1
# F2B_AUTH_MODE=off
# F2B_ADMIN_TOKEN=
# F2B_SANDBOX_API_KEY=   # web BFF 上游产品密钥（auth=api_key 时）
# F2B_CUBE_API_URL=http://127.0.0.1:<cube-api-port>
# F2B_CUBE_API_TOKEN=
